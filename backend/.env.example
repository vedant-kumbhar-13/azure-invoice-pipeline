# ══════════════════════════════════════════════════════
# InvoiceAI — Environment Variables
# Copy to .env and fill in your values
# ══════════════════════════════════════════════════════

# === AZURE SERVICES ===
# Get from Azure Portal → AI Document Intelligence → Keys and Endpoint
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your_key_here

# Get from Azure Portal → Storage Account → Access Keys
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_STORAGE_CONTAINER_NAME=invoices-test

# === DATABASE ===
# REQUIRED: PostgreSQL only — SQLite cannot handle concurrent writes (multiple uvicorn workers).
# Using SQLite in production will cause "database is locked" errors under any real load.
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://invoiceai_user:CHANGE_ME@localhost:5432/invoiceai

# === AUTH ===
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# MUST be at least 32 characters
JWT_SECRET=generate_a_secure_random_32_character_secret_here

# === OPTIONAL ===
ENVIRONMENT=dev
LOG_LEVEL=INFO

# BUG-B1: Required in production \u2014 set to the actual deployed frontend URL.
# This is the ONLY origin allowed by CORS when ENVIRONMENT=production.
# Example: https://invoiceai.yourdomain.com  or your AWS CloudFront URL
FRONTEND_URL=https://your-frontend-url.example.com

# === SERVER ===
# Port the FastAPI backend listens on.
# Must match VITE_API_URL in the React frontend's .env.local
APP_PORT=8001
