# ══════════════════════════════════════════════════════
# InvoiceAI — Environment Variables
# Copy to .env and fill in your values
# ══════════════════════════════════════════════════════

# === AZURE SERVICES ===
# Get from Azure Portal → AI Document Intelligence → Keys and Endpoint
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your_key_here

# Get from Azure Portal → Storage Account → Access Keys
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_STORAGE_CONTAINER_NAME=invoices-test

# === DATABASE ===
# REQUIRED: PostgreSQL only — SQLite cannot handle concurrent writes (multiple uvicorn workers).
# Using SQLite in production will cause "database is locked" errors under any real load.
# For local dev, sqlite:///./invoiceai.db is fine.
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://invoiceai_user:CHANGE_ME@localhost:5432/invoiceai

# === AUTH ===
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# MUST be at least 32 characters
JWT_SECRET=generate_a_secure_random_32_character_secret_here

# === OPTIONAL ===
ENVIRONMENT=dev
LOG_LEVEL=INFO

# BUG-B1: Required in production — set to the actual deployed frontend URL.
# This is the ONLY origin allowed by CORS when ENVIRONMENT=production.
# Example: https://invoiceai.yourdomain.com  or your AWS CloudFront URL
FRONTEND_URL=https://your-frontend-url.example.com

# === SERVER ===
# Port the FastAPI backend listens on.
# Must match VITE_API_URL in the React frontend's .env.local
APP_PORT=8001


# ══════════════════════════════════════════════════════
# [NEW] PAYMENT REMINDERS — SMTP / Email
# ══════════════════════════════════════════════════════
#
# Gmail setup (recommended for dev/small teams):
#   1. Enable 2-Step Verification on your Google account:
#      https://myaccount.google.com/security
#   2. Go to Google Account → Security → App Passwords
#      (search "App Passwords" if you don't see it directly)
#   3. Generate a new App Password — select app "Mail", device "Other"
#   4. Copy the 16-character password (remove spaces) into SMTP_PASSWORD
#   5. Do NOT use your normal Gmail login password — it will be rejected
#      by Google's SMTP servers for security reasons.
#
# Outlook / Office 365:
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
#   SMTP_USE_TLS=true
#
# Local testing without sending real emails (Mailhog/Mailtrap):
#   SMTP_HOST=localhost
#   SMTP_PORT=1025
#   SMTP_USE_TLS=false
#   EMAIL_ENABLED=true

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true

# Your full Gmail address
SMTP_USERNAME=youremail@gmail.com

# 16-character Gmail App Password (NOT your normal password)
SMTP_PASSWORD=your_16_char_app_password

# Display name shown in recipient inbox
SMTP_FROM_NAME=Invoice Pipeline

# Leave blank to use SMTP_USERNAME as the "From" address
SMTP_FROM_EMAIL=

# Master switch — set to false to disable ALL outgoing emails
# (in-app notifications still work even if this is false)
EMAIL_ENABLED=true


# ══════════════════════════════════════════════════════
# [NEW] PAYMENT REMINDERS — Scheduler
# ══════════════════════════════════════════════════════

# How often (in hours) the background job scans for due payments
# and fires reminders. Default: every 6 hours.
REMINDER_SCHEDULER_INTERVAL_HOURS=6

# System-wide default reminder schedule (days before due date).
# Comma-separated, no spaces. Each user can override this in
# their own Reminder Settings (Settings → Reminders page).
# Default: remind 7 days, 3 days, and 1 day before the due date.
REMINDER_DEFAULT_DAYS_BEFORE=7,3,1
